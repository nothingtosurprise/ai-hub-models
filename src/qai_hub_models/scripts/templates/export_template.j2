    quantized_model{{ optional_s }}: {{ "ComponentGroup[hub.Model] | None" if is_collection_model else "hub.Model | None" }} = None
    if precision != Precision.float:
        if quantized_model_id:
            {%- if is_collection_model %}
            quantized_models = ComponentGroup({
                component: hub_model
                for component in components
                if (hub_model := hub.get_model(quantized_model_id[component])) is not None
            })
