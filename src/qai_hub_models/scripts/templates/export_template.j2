            flat_onnx_jobs: dict[str, hub.client.CompileJob] = {}
            seen_onnx_components: set[str] = set()
            for (comp_name, _gn), job in onnx_compile_result.component_graph_names.items():
                if comp_name not in seen_onnx_components:
