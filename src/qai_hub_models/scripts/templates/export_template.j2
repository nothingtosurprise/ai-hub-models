{% if not is_precompiled %}
def download_model(
    output_dir: os.PathLike | str,
    model: {{ "MultiGraphPretrainedCollectionModel" if has_multi_graph and is_collection_model else "PretrainedCollectionModel" if is_collection_model else "BaseModel" }},
    runtime: TargetRuntime,
    precision: Precision,
    tool_versions: ToolVersions,
    target_model{{ optional_s }}: {{ "ComponentGroup[hub.Model]" if is_collection_model else "hub.Model" }},
    {%- if not is_collection_model %}
    model_name: str,
    {%- endif %}
    zip_assets: bool,
    hub_device: hub.Device | None = None,
) -> Path:
    output_folder_name = os.path.basename(output_dir)
    output_path = get_next_free_path(output_dir)

    with tempfile.TemporaryDirectory() as tmpdir:
        dst_path = Path(tmpdir) / output_folder_name
        dst_path.mkdir()

        {% if is_collection_model -%}
        # Download models and capture filenames, then generate metadata
        model_file_metadata = {}
        for component_name, target_model in target_models.items():
        {%- endif %}
        {%- filter indent(width=4 if is_collection_model else 0) %}
        if target_model.model_type == hub.SourceModelType.ONNX:
            onnx_result = download_and_unzip_workbench_onnx_model(target_model, dst_path, {{- model_or_comp_name -}})
            model_file_name = onnx_result.onnx_graph_name
        else:
            downloaded_path = target_model.download(os.path.join(dst_path, {{- model_or_comp_name -}}))
            model_file_name = os.path.basename(downloaded_path)
        {%- if is_collection_model %}

        # Generate metadata using the actual downloaded filename
        model_file_metadata[model_file_name] = ModelFileMetadata.from_hub_model(target_model)
        # Merge semantic metadata from get_input_spec()
        {%- if has_multi_graph %}
        all_input_specs = model.get_input_spec()
        for _graph_spec in all_input_specs[component_name].values():
            merge_input_metadata(model_file_metadata[model_file_name], _graph_spec)
        {%- else %}
        component = model.components[component_name]
        merge_input_metadata(model_file_metadata[model_file_name], component.get_input_spec())
        merge_output_metadata(model_file_metadata[model_file_name], component.get_output_spec())
        {%- endif %}
        {%- endif %}
        {%- endfilter %}

        # Extract and save metadata alongside downloaded model
        metadata_path = dst_path / "metadata.json"
        {%- if is_collection_model %}
        model_metadata = ModelMetadata(model_id=MODEL_ID, model_name="{{ model_display_name }}", runtime=runtime, precision=precision, tool_versions=tool_versions, model_files=model_file_metadata, chipset_attributes=ChipsetAttributes.from_hub_device(hub_device) if runtime.is_aot_compiled else None)
        {%- else %}
        file_metadata = ModelFileMetadata.from_hub_model(target_model)
        # Merge semantic metadata from get_input_spec()
        merge_input_metadata(file_metadata, model.get_input_spec())
        merge_output_metadata(file_metadata, model.get_output_spec())
        model_metadata = ModelMetadata(model_id=MODEL_ID, model_name="{{ model_display_name }}", runtime=runtime, precision=precision, tool_versions=tool_versions, model_files={model_file_name: file_metadata}, chipset_attributes=ChipsetAttributes.from_hub_device(hub_device) if runtime.is_aot_compiled else None)
        {%- endif %}

        # Dump supplementary files into the model folder
        model.write_supplementary_files(dst_path, model_metadata)

        model_metadata.to_json(metadata_path)
        if zip_assets:
            output_path = Path(shutil.make_archive(str(output_path), "zip", root_dir=tmpdir, base_dir=output_folder_name))
        else:
            shutil.move(dst_path, output_path)

    return output_path
{%- else %}
def save_model(
    output_dir: os.PathLike | str,
    tool_versions: ToolVersions | None,
    {%- if is_collection_model %}
    model: PrecompiledCollectionModel,
    components: list[str],
    {%- else %}
    model: BasePrecompiledModel,
    {%- endif %}
    zip_assets: bool,
) -> Path:
    output_folder_name = os.path.basename(output_dir)
    output_path = get_next_free_path(output_dir)

    with tempfile.TemporaryDirectory() as tmpdir:
        dst_path = Path(tmpdir) / output_folder_name
        dst_path.mkdir()

        {%- if is_collection_model %}
        for component_name in components:
            path = cast(BasePrecompiledModel, model.components[component_name]).get_target_model_path()
            shutil.copyfile(src=path, dst=dst_path / os.path.basename(path))
        {%- else %}
        path = model.get_target_model_path()
        shutil.copyfile(src=path, dst=dst_path / os.path.basename(path))
        {%- endif %}

        if zip_assets:
            output_path = Path(shutil.make_archive(str(output_path), "zip", root_dir=tmpdir, base_dir=output_folder_name))
        else:
            shutil.move(dst_path, output_path)

    return output_path
{%- endif %}

def export_model(
    device: hub.Device,
    {{- "\n    components: list[str] | None = None," if is_collection_model else "" }}
    {%- if not is_precompiled  %}
    precision: Precision = {{ "Precision." + default_aihub_job_precision }},
    {%- endif %}
    {%- if can_use_quantize_job %}
    num_calibration_samples: int | None = {{ num_calibration_samples if num_calibration_samples else "None" }},
    quantized_model_id: {{ "dict[str, str]" if is_collection_model else "str" }} | None = None,
    skip_compiling: bool = False,
    {%- endif %}
