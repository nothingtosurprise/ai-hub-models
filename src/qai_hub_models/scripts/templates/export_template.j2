def profile_model(
    model_name: str,
    device: hub.Device,
    options: {{ "MultiGraphComponentGroup[str]" if is_collection_model else "MultiGraphGroup[str]" }},
    {%- if is_precompiled %}
    uploaded_models: dict[str, hub.Model],
    {%- else %}
    target_model{{ optional_s }}: {{ "ComponentGroup[hub.Model]" if is_collection_model else "hub.Model" }},
    {%- endif %}
    {%- if is_collection_model %}
    components: list[str] | None = None,
    {%- endif %}
    graph_names: list[str] | None = None,
) -> {{ "MultiGraphComponentGroup[hub.client.ProfileJob]" if is_collection_model else "MultiGraphGroup[hub.client.ProfileJob]" }}:
    {%- if is_collection_model %}
    profile_jobs: MultiGraphComponentGroup[hub.client.ProfileJob] = MultiGraphComponentGroup()
    for (component_name, graph_name), opts in options.component_graph_names.items():
        if components is not None and component_name not in components:
            continue
        if graph_names is not None and graph_name not in graph_names:
            continue
        print(f"Profiling model {component_name} on a hosted device.")
        job_name = f"{model_name}_{component_name}_{graph_name}"
        submitted_profile_job = hub.submit_profile_job(
            model={{ component_hub_model }},
            device=device,
            name=job_name,
            options=opts,
        )
        profile_jobs.component_graph_names[(component_name, graph_name)] = cast(hub.client.ProfileJob, submitted_profile_job)
    return profile_jobs
    {%- else %}
    profile_jobs: MultiGraphGroup[hub.client.ProfileJob] = MultiGraphGroup()
    for graph_name, opts in options.items():
        if graph_names is not None and graph_name not in graph_names:
            continue
        print(f"Profiling model {model_name} on a hosted device.")
        job_name = f"{model_name}_{graph_name}"
        submitted_profile_job = hub.submit_profile_job(
            model=target_model,
            device=device,
            name=job_name,
            options=opts,
        )
        profile_jobs[graph_name] = cast(hub.client.ProfileJob, submitted_profile_job)
    return profile_jobs
    {%- endif %}

