+def bilinear_sampler_int_frac(img, base, flow):
+    """Bilinear sampling using F.grid_sample on combined base+flow coordinates.
+
+    Single F.grid_sample call — QNN maps this natively to its own grid sampler
+    op with no int64 indices, making it compatible with TFLite and QNN HTP.
+    """
+    H, W = img.shape[-2:]
+    coords = base + flow
+    xn = coords[..., 0:1] * (2.0 / (W - 1)) - 1.0
+    yn = coords[..., 1:2] * (2.0 / (H - 1)) - 1.0
+    grid = torch.cat([xn, yn], dim=-1)
+    return F.grid_sample(img, grid, mode='bilinear',
+                         padding_mode='zeros', align_corners=True)
+
